# Local development Caddy config
#
# Same-machine access (laptop):  http://localhost:3020  (direct, no Caddy)
# Tablet/phone access over LAN:  https://<your-LAN-IP>:8443
#   → Camera/mic/speech recognition work because HTTPS context is met.
#   → On first visit, accept the self-signed cert warning on the device.

# HTTPS for LAN devices (self-signed cert auto-generated by Caddy)
:443 {
  tls internal
  reverse_proxy app:3000
}

# HTTP redirect to HTTPS
:80 {
  redir https://{host}{uri} permanent
}
