# Local development Caddy config
#
# Same-machine access (laptop):  http://localhost:3000  (direct, no Caddy)
# Tablet access over LAN:        https://<your-LAN-IP>:8443
#   → Camera/mic work because HTTPS context is met.
#   → Accept the self-signed cert warning once on the tablet.

localhost {
  reverse_proxy app:3000
}

# Catch-all for LAN IP access (tablets, other devices on same network)
:80 {
  reverse_proxy app:3000
}
